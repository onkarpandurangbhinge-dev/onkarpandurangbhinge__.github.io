<!DOCTYPE html>
<html>

<head>
<title>Food Menu</title>

<style>

body{
font-family: Arial;
background:#f4f4f4;
text-align:center;
}

h1{
background:red;
color:white;
padding:20px;
}

.menu{
display:flex;
justify-content:center;
flex-wrap:wrap;
}

.food{
background:white;
margin:20px;
padding:20px;
width:220px;
border-radius:10px;
box-shadow:0px 0px 10px gray;
}

.food img{
width:200px;
height:150px;
border-radius:10px;
}

button{
background:red;
color:white;
border:none;
padding:10px;
margin-top:10px;
cursor:pointer;
}

button:hover{
background:darkred;
}

</style>

</head>

<body>

<h1>Food Delivery Menu</h1>

<div class="menu">

<div class="food">
<img src="pizza.jpg">
<h2>Pizza</h2>
<button>Order Now</button>
</div>

<div class="food">
<img src="burger.jpg">
<h2>Burger</h2>
<button>Order Now</button>
</div>

<div class="food">
<img src="biryani.jpg">
<h2>Biryani</h2>
<button>Order Now</button>
</div>

<div class="food">
<img src="dosa.jpg">
<h2>Dosa</h2>
<button>Order Now</button>
</div>

</div>

</body>
</html>
